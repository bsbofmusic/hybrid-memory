{
  "name": "@bsbofmusic/hybrid-memory",
  "version": "0.2.4",
  "description": "Hybrid Memory MCP Server — Hindsight + memos unified validation over memos PostgreSQL, reusing OpenClaw memorySearch embedding config",
  "main": "index.js",
  "bin": {
    "hybrid-memory": "index.js"
  },
  "scripts": {
    "start": "node index.js",
    "doctor": "node doctor.js",
    "pm2:start": "pm2 start pm2.hybrid-memory.config.cjs",
    "pm2:restart": "pm2 restart hybrid-memory",
    "pm2:stop": "pm2 stop hybrid-memory",
    "feed:hindsight": "node feed_hindsight_from_memos.js"
  },
  "dependencies": {
    "@vectorize-io/hindsight-client": "^0.4.20",
    "pg": "^8.11.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "openclaw",
    "memory",
    "mcp",
    "hybrid-memory",
    "memos",
    "semantic-search"
  ],
  "author": "bsbofmusic",
  "license": "MIT",
  "files": [
    "index.js",
    "doctor.js",
    "hindsight.js",
    "feed_hindsight_from_memos.js",
    "pm2.hybrid-memory.config.cjs",
    "README.md",
    "start.sh"
  ],
  "publishConfig": {
    "access": "public"
  }
}
